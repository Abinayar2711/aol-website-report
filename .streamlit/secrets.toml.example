# Template. Copy to .streamlit/secrets.toml for local testing (gitignored), and paste
# the same [auth] block into Streamlit Cloud under App settings -> Secrets.
#
# client_id and client_secret are the SAME across all three apps -- one Google OAuth
# client serves all of them. Only redirect_uri and cookie_secret differ per app.

[auth]
# Local testing uses localhost; on Streamlit Cloud set this to the deployed URL.
redirect_uri = "http://localhost:8501/oauth2callback"

# Signs the login cookie. Must be unique per app and never shared or committed.
cookie_secret = "PASTE_A_UNIQUE_RANDOM_STRING_HERE"

client_id = "xxxxxxxxxxxx.apps.googleusercontent.com"
client_secret = "GOCSPX-xxxxxxxxxxxxxxxxxxxx"

server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
